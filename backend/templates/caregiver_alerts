<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Alerts · Caregiver</title>
    <link rel="stylesheet" href="{{ url_for('static', filename='styles.css') }}">
    <link rel="stylesheet" href="{{ url_for('static', filename='schedule.css') }}">
    <link rel="stylesheet" href="{{ url_for('static', filename='caregiver.css') }}">
</head>
<body class="caregiver-page">
    <div class="dashboard-container">
        <aside class="sidebar">
            <h2 class="logo">
                <span class="logo-mark">M</span>
                <span>MediTrack</span>
            </h2>
            <nav>
                <p class="nav-section-label">Caregiver</p>
                <ul>
                    <li><a href="{{ url_for('caregiver_dashboard') }}" class="sidebar-link"><span class="sidebar-icon">⌂</span><span>Overview</span></a></li>
                    <li><a href="{{ url_for('caregiver_schedule') }}" class="sidebar-link"><span class="sidebar-icon">🕒</span><span>Schedule</span></a></li>
                    <li><a href="{{ url_for('caregiver_adherence') }}" class="sidebar-link"><span class="sidebar-icon">◔</span><span>Adherence</span></a></li>
                    <li><a href="{{ url_for('caregiver_notes_page') }}" class="sidebar-link"><span class="sidebar-icon">📝</span><span>Notes</span></a></li>
                    <li><a href="{{ url_for('caregiver_alerts') }}" class="sidebar-link active"><span class="sidebar-icon">!</span><span>Alerts</span></a></li>
                </ul>
            </nav>
            <div class="sidebar-bottom">
                <a href="{{ url_for('auth.logout') }}" class="sidebar-link logout-link">
                    <span class="sidebar-icon">⇦</span><span>Sign out</span>
                </a>
            </div>
        </aside>

        <div class="content-wrapper">
            <section class="main-panel">
                <header class="top-bar">
                    <div>
                        <h1>Alerts</h1>
                        <p>Issues and events that need {{ ctx.active_patient_name }}'s attention</p>
                    </div>
                </header>

                <div class="patient-picker">
                    <div class="patient-avatar">{{ (ctx.active_patient_name or '?')[0] }}</div>
                    <div class="patient-picker-info">
                        <p class="picker-label">Currently monitoring</p>
                        <h2>{{ ctx.active_patient_name or 'No patient selected' }}</h2>
                        <span>{{ ctx.assigned_patients|length }} patient{{ '' if ctx.assigned_patients|length == 1 else 's' }} assigned to you</span>
                    </div>
                    <details class="picker-dropdown">
                        <summary class="picker-button">Change patient ▾</summary>
                        <div class="picker-menu">
                            {% for p in ctx.assigned_patients %}
                                <a href="{{ url_for('caregiver_select_patient', patient_id=p.patient_id) }}"
                                   class="picker-menu-item {% if p.patient_id == ctx.active_patient_id %}selected{% endif %}">
                                    {{ p.full_name }}
                                </a>
                            {% endfor %}
                        </div>
                    </details>
                </div>

                <div class="caregiver-panel">
                    {% if alerts %}
                        {% for alert in alerts %}
                            <div class="alert-box {{ alert.type }}">
                                <strong>{{ alert.message }}</strong>
                                <p>at {{ alert.time }}</p>
                            </div>
                        {% endfor %}
                    {% else %}
                        <p class="empty-state">No alerts to show right now.</p>
                    {% endif %}
                </div>
            </section>
        </div>
    </div>
</body>
</html>